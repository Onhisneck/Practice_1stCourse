#include <iostream>
#include <vector>
#include <climits>


int minPath(const std::vector<std::vector<int>>& triangle, int row, int col) {
    int n = triangle.size();

    if (row == n - 1) {
        return triangle[row][col];
    }
    // Спускаемся либо вниз-влево, либо вниз-вправо
    int left  = minPath(triangle, row + 1, col);
    int right = minPath(triangle, row + 1, col + 1);

    return triangle[row][col] + std::min(left, right);
}

int main() {
    int n;
    std::cin >> n;

    std::vector<std::vector<int>> triangle(n);
    for (int i = 0; i < n; i++) {
        triangle[i].resize(i + 1);
        for (int j = 0; j <= i; j++) {
            std::cin >> triangle[i][j];
        }
    }

    int result = minPath(triangle, 0, 0);
    std::cout << result << std::endl;

    return 0;
}
